{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finance",
  "description": "Loan and financing rules for BYD Miri",
  "type": "object",
  "required": ["interestRate", "loanMargin", "defaultTenure", "availableTenures", "additionalRebate"],
  "properties": {
    "interestRate": { "type": "number", "description": "Flat interest rate percentage" },
    "interestRateUnit": { "type": "string", "enum": ["%"] },
    "loanMargin": { "type": "number", "description": "Maximum loan margin as percentage of price" },
    "loanMarginUnit": { "type": "string", "enum": ["%"] },
    "defaultTenure": { "type": "integer", "description": "Default loan tenure in years" },
    "defaultTenureUnit": { "type": "string", "enum": ["years"] },
    "availableTenures": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Available loan tenure options in years"
    },
    "tenureUnit": { "type": "string", "enum": ["years"] },
    "additionalRebate": {
      "type": "object",
      "description": "CSP/GSP/SSP additional rebate configuration",
      "required": ["default", "overrides", "label"],
      "properties": {
        "default": { "type": "integer", "description": "Default additional rebate amount in RM" },
        "overrides": {
          "type": "object",
          "description": "Model-specific overrides for additional rebate",
          "additionalProperties": { "type": "integer" }
        },
        "label": { "type": "string", "description": "Display label for the additional rebate" }
      }
    },
    "disclaimer": { "type": "string", "description": "Legal disclaimer text" }
  }
}
